{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "registryVersion": 2,
  "site": "storage-swa",
  "description": "Block registry for page content managed by the static HTML site editor and serialized into saved pages.",
  "documentModel": {
    "type": "document",
    "metaFields": {
      "title": {
        "type": "string",
        "required": true
      },
      "path": {
        "type": "string",
        "required": true,
        "pattern": ".*\\.html$"
      },
      "status": {
        "type": "string",
        "enum": ["draft", "published"],
        "default": "draft"
      }
    },
    "blockShape": {
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "children": {
          "type": "array",
          "default": []
        }
      }
    }
  },
  "blockTypes": {
    "paragraph": {
      "status": "implemented",
      "category": "text",
      "label": "Paragraph",
      "icon": "ic_fluent_text_24_regular",
      "description": "Body copy with inline formatting and alignment.",
      "editorModel": {
        "children": false,
        "propKeys": ["html", "align", "className"]
      },
      "defaults": {
        "html": "",
        "align": "left",
        "className": ""
      },
      "supports": {
        "inlineEditing": true,
        "alignment": ["left", "center", "right", "justify"],
        "toolbar": ["bold", "italic", "link", "alignment", "transform"],
        "children": false
      },
      "output": {
        "tag": "p"
      },
      "propsSchema": {
        "type": "object",
        "properties": {
          "html": { "type": "string" },
          "align": {
            "type": "string",
            "enum": ["left", "center", "right", "justify"],
            "default": "left"
          },
          "className": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "heading": {
      "status": "implemented",
      "category": "text",
      "label": "Heading",
      "icon": "ic_fluent_text_bold_24_regular",
      "description": "Semantic heading block with level and alignment controls.",
      "editorModel": {
        "children": false,
        "propKeys": ["text", "level", "align"]
      },
      "defaults": {
        "text": "Heading",
        "level": 2,
        "align": "left"
      },
      "supports": {
        "inlineEditing": true,
        "alignment": ["left", "center", "right"],
        "toolbar": ["level", "alignment", "transform"],
        "children": false
      },
      "output": {
        "tag": "h{level}"
      },
      "propsSchema": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "level": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6,
            "default": 2
          },
          "align": {
            "type": "string",
            "enum": ["left", "center", "right"],
            "default": "left"
          }
        },
        "additionalProperties": false
      }
    },
    "image": {
      "status": "implemented",
      "category": "media",
      "label": "Image",
      "icon": "ic_fluent_image_24_regular",
      "description": "Single image with caption, sizing, alignment, and link support.",
      "editorModel": {
        "children": false,
        "propKeys": ["src", "alt", "caption", "linkHref", "width", "height", "align", "className"]
      },
      "defaults": {
        "src": "",
        "alt": "",
        "caption": "",
        "linkHref": "",
        "width": "",
        "height": "",
        "align": "wide",
        "className": ""
      },
      "supports": {
        "alignment": ["left", "center", "right", "wide", "full"],
        "toolbar": ["replace", "alignment", "caption", "link"],
        "assetSources": ["upload", "library", "url"],
        "children": false
      },
      "output": {
        "tag": "figure"
      },
      "propsSchema": {
        "type": "object",
        "properties": {
          "src": { "type": "string" },
          "alt": { "type": "string" },
          "caption": { "type": "string" },
          "linkHref": { "type": "string" },
          "width": { "type": ["string", "integer"] },
          "height": { "type": ["string", "integer"] },
          "align": {
            "type": "string",
            "enum": ["left", "center", "right", "wide", "full"],
            "default": "wide"
          },
          "className": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "cover": {
      "status": "implemented",
      "category": "media",
      "label": "Cover",
      "icon": "ic_fluent_image_multiple_24_regular",
      "description": "Hero-style cover section with background media, overlay, and nested content.",
      "editorModel": {
        "children": true,
        "propKeys": ["background", "overlay", "minHeight", "contentPosition", "style", "className"]
      },
      "defaults": {
        "background": {
          "type": null,
          "src": null,
          "alt": "",
          "poster": "",
          "focalPoint": { "x": 0.5, "y": 0.5 },
          "fixed": false
        },
        "overlay": { "color": "#000000", "opacity": 0.5 },
        "minHeight": "50vh",
        "contentPosition": "center center",
        "style": { "layout": "default", "spacing": {} },
        "className": ""
      },
      "supports": {
        "alignment": ["default", "wide", "full"],
        "assetSources": ["upload", "library", "featured", "url"],
        "children": true
      },
      "output": {
        "tag": "section"
      },
      "propsSchema": {
        "type": "object",
        "properties": {
          "background": { "type": "object" },
          "overlay": { "type": "object" },
          "minHeight": { "type": "string" },
          "contentPosition": { "type": "string" },
          "style": { "type": "object" },
          "className": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
